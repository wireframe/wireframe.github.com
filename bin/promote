#!/usr/bin/env bash

set -e

if [ -z "$1" ]; then
  echo "Usage: bin/promote <draft> [publish-date]"
  echo "Example: bin/promote engineering-your-remote-engineering-team"
  echo "         bin/promote 2026-05-29-engineering-your-remote-engineering-team.md"
  echo "         bin/promote my-post 2026-06-01"
  echo
  echo "Promotes a draft from _drafts/ to _posts/ using 'git mv' to preserve history."
  echo "Defaults the publish date to today; pass a YYYY-MM-DD date to override."
  exit 1
fi

INPUT="$1"
PUBLISH_DATE="${2:-$(date +%Y-%m-%d)}"

if ! [[ "$PUBLISH_DATE" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
  echo "Error: publish date must be in YYYY-MM-DD format (got '$PUBLISH_DATE')"
  exit 1
fi

NAME=$(basename "$INPUT" .md)

MATCHES=$(find _drafts -maxdepth 1 -type f -name "*${NAME}.md")
COUNT=$(echo -n "$MATCHES" | grep -c '^' || true)

if [ "$COUNT" -eq 0 ]; then
  echo "Error: no draft matching '$NAME' found in _drafts/"
  exit 1
fi

if [ "$COUNT" -gt 1 ]; then
  echo "Error: '$NAME' matches multiple drafts; be more specific:"
  echo "$MATCHES"
  exit 1
fi

DRAFT="$MATCHES"
SLUG=$(basename "$DRAFT" .md | sed -E 's/^[0-9]{4}-[0-9]{2}-[0-9]{2}-//')
POST="_posts/${PUBLISH_DATE}-${SLUG}.md"

if [ -f "$POST" ]; then
  echo "Error: $POST already exists"
  exit 1
fi

git mv "$DRAFT" "$POST"

echo "Promoted draft to post: $POST"
