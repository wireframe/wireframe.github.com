#!/usr/bin/env bash

set -e

usage() {
  echo "Usage: bin/promote <path-to-draft> [--date YYYY-MM-DD]"
  echo "Example: bin/promote _drafts/2026-05-29-my-post.md"
  echo "         bin/promote _drafts/2026-05-29-my-post.md --date 2026-06-01"
  echo
  echo "Promotes a draft from _drafts/ to _posts/ using 'git mv' to preserve history."
  echo "Defaults the publish date to today; pass --date to override."
}

DRAFT=""
PUBLISH_DATE="$(date +%Y-%m-%d)"

while [ $# -gt 0 ]; do
  case "$1" in
    --date)
      PUBLISH_DATE="$2"
      shift 2
      ;;
    --date=*)
      PUBLISH_DATE="${1#--date=}"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      DRAFT="$1"
      shift
      ;;
  esac
done

if [ -z "$DRAFT" ]; then
  usage
  exit 1
fi

if ! [[ "$PUBLISH_DATE" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
  echo "Error: publish date must be in YYYY-MM-DD format (got '$PUBLISH_DATE')"
  exit 1
fi

if [ ! -f "$DRAFT" ]; then
  echo "Error: draft not found: $DRAFT"
  exit 1
fi

SLUG=$(basename "$DRAFT" .md | sed -E 's/^[0-9]{4}-[0-9]{2}-[0-9]{2}-//')
POST="_posts/${PUBLISH_DATE}-${SLUG}.md"

if [ -f "$POST" ]; then
  echo "Error: $POST already exists"
  exit 1
fi

git mv "$DRAFT" "$POST"

echo "Promoted draft to post: $POST"
